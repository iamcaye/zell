{
  "name": "zell-grid-engine",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run build:core && bun run build:react && bun run build:demo && node scripts/check-bundle-size.mjs",
    "build:core": "cd packages/core && bun run build",
    "build:react": "cd packages/react && bun run build",
    "build:demo": "cd apps/demo && bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "cd apps/demo && bun run dev"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.3.6",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "vitest": "^3.1.1"
  }
}
