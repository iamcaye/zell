{
  "name": "@zell/grid-react",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "@zell/grid-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  }
}
